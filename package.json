{
  "name": "n8n-nodes-gmaps-paginator",
  "version": "1.1.0",
  "description": "n8n community node to paginate Google Maps search results via configurable HTTP proxy",
  "keywords": [
    "n8n-community-node-package",
    "google-maps",
    "scraping",
    "evomi",
    "proxy"
  ],
  "license": "MIT",
  "homepage": "https://github.com/YOUR_GITHUB_USERNAME/n8n-nodes-gmaps-paginator",
  "author": {
    "name": "Akhilesh Chitlangia",
    "email": "akhilesh@chitlangia.co"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_GITHUB_USERNAME/n8n-nodes-gmaps-paginator.git"
  },
  "engines": {
    "node": ">=18.10"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js nodes credentials package.json"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/EvomiProxyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/GoogleMapsPaginator/GoogleMapsPaginator.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.120.13",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "axios": "^1.16.1"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
